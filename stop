#!/bin/bash
# workstation-webspace-guacamole: Stop all services
set -euo pipefail

if pidof systemd > /dev/null 2>&1; then
  echo "Stopping..."
  sudo systemctl stop guacd 2>/dev/null || true
  sudo systemctl stop tomcat9 2>/dev/null || true
else
  echo "Stopping (direct mode)..."
  pkill -f "Xvfb :99" 2>/dev/null || true
  pkill -f "fluxbox -display :99" 2>/dev/null || true
  pkill -f "x11vnc -display :99" 2>/dev/null || true
  pkill -f guacd 2>/dev/null || true
  export CATALINA_HOME="/usr/share/tomcat9"
  export CATALINA_BASE="/var/lib/tomcat9"
  sudo -E /usr/share/tomcat9/bin/catalina.sh stop 2>/dev/null || true
fi
echo "Stopped."
