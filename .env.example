# Workstation Center OS configuration

# Edition: tiny (fluxbox) or pro (XFCE4)
# Default: tiny
EDITION=tiny

# Password for Guacamole web UI login
GUAC_PASSWORD=changeme

# Password for VNC connections
VNC_PASSWORD=changeme

# Screen resolution (default: 1920x1080)
SCREEN_RESOLUTION=1920x1080

# Color depth (default: 24)
COLOR_DEPTH=24
