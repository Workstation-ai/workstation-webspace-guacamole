#!/bin/bash
# Workstation Center OS - One-command setup
# Usage: ./run [--edition tiny|pro] [--agent-preset-workspace]
set -euo pipefail

# --- Parse flags ---
EDITION="tiny"
AGENT_WORKSPACE=false
for arg in "$@"; do
  case "$arg" in
    --edition) shift; EDITION="${1:-tiny}"; shift ;;
    --edition=tiny) EDITION="tiny" ;;
    --edition=pro) EDITION="pro" ;;
    --agent-preset-workspace) AGENT_WORKSPACE=true ;;
  esac
done

# Validate edition
if [[ ! "$EDITION" =~ ^(tiny|pro)$ ]]; then
  echo "Error: Invalid edition '$EDITION'. Use 'tiny' or 'pro'."
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
USER_HOME="$HOME"
USER_NAME="$(whoami)"

# --- Load .env ---
if [ ! -f "$SCRIPT_DIR/.env" ]; then
  echo "Error: .env file not found."
  echo "Copy .env.example to .env and configure it:"
  echo "  cp .env.example .env"
  echo "  nano .env"
  exit 1
fi

source "$SCRIPT_DIR/.env"

if [ -z "${GUAC_PASSWORD:-}" ]; then
  echo "Error: GUAC_PASSWORD is not set in .env"
  exit 1
fi

if [ -z "${VNC_PASSWORD:-}" ]; then
  echo "Error: VNC_PASSWORD is not set in .env"
  exit 1
fi

RESOLUTION="${SCREEN_RESOLUTION:-1920x1080}"
DEPTH="${COLOR_DEPTH:-24}"
RES_X="${RESOLUTION%x*}"
RES_Y="${RESOLUTION#*x}"

GUAC_VERSION="1.6.0"
TOMCAT_VERSION="9"
JAVA_HOME="${JAVA_HOME:-/usr}"

# --- Check for systemd ---
USE_SYSTEMD=true
if ! pidof systemd > /dev/null 2>&1; then
  echo "Note: systemd not detected. Running in direct mode (no auto-restart)."
  USE_SYSTEMD=false
fi

echo "=== Workstation Center OS ==="
echo "Edition: ${EDITION^}"
echo "Resolution: ${RESOLUTION}x${DEPTH}bit"
echo "User: ${USER_NAME}"
echo "Guacamole: v${GUAC_VERSION}"
echo ""

# --- Cleanup previous run ---
echo "Cleaning up previous services..."
if [ "$USE_SYSTEMD" = true ]; then
  sudo systemctl stop guacd 2>/dev/null || true
  sudo systemctl stop tomcat9 2>/dev/null || true
fi
pkill -9 -f "Xvfb :99" 2>/dev/null || true
pkill -9 -f "fluxbox" 2>/dev/null || true
pkill -9 -f "startxfce4" 2>/dev/null || true
pkill -9 -f "xfce4-session" 2>/dev/null || true
pkill -9 -f "x11vnc" 2>/dev/null || true
pkill -9 -f "websockify" 2>/dev/null || true
# Kill any cloudflared tunnels pointing to our ports (6080 or 8080)
for pid in $(pgrep -f "cloudflared.*--url.*:8080"); do kill -9 $pid 2>/dev/null; done
for pid in $(pgrep -f "cloudflared.*--url.*:6080"); do kill -9 $pid 2>/dev/null; done
rm -f /tmp/.X99-lock /tmp/.X11-unix/X99 2>/dev/null || true
sleep 2

# --- Packages ---
echo "[1/9] Installing dependencies..."
sudo apt-get update -qq
DEBIAN_FRONTEND=noninteractive sudo apt-get install -y -qq \
  build-essential libcairo2-dev libjpeg-turbo8-dev libpng-dev libtool-bin libossp-uuid-dev \
  libavcodec-dev libavformat-dev libavutil-dev libswscale-dev \
  freerdp2-dev libpango1.0-dev libssh2-1-dev libtelnet-dev \
  libvncserver-dev libwebsockets-dev libpulse-dev libssl-dev \
  libvorbis-dev libwebp-dev \
  curl wget git unzip \
  x11vnc xdg-utils xsel dbus-x11 xdotool wmctrl fonts-dejavu fonts-noto-cjk \
  2>&1 | tail -5

# Install edition-specific packages
echo "[2/9] Installing desktop environment (${EDITION})..."
if [ "$EDITION" = "pro" ]; then
  bash "${SCRIPT_DIR}/scripts/pro/install-xfce4.sh"
else
  bash "${SCRIPT_DIR}/scripts/tiny/install-fluxbox.sh"
fi

# Install Java if not present
if ! command -v java &> /dev/null; then
  echo "Installing Java..."
  DEBIAN_FRONTEND=noninteractive sudo apt-get install -y -qq default-jdk 2>&1 | tail -3
fi

# Install Tomcat 9
if [ ! -d "/var/lib/tomcat${TOMCAT_VERSION}" ]; then
  echo "Installing Tomcat ${TOMCAT_VERSION}..."
  # Add Ubuntu 22.04 repo for Tomcat 9 if needed
  if ! apt-cache show tomcat9 &> /dev/null 2>&1; then
    sudo add-apt-repository -y "deb http://archive.ubuntu.com/ubuntu jammy universe" 2>/dev/null || true
    sudo apt-get update -qq
  fi
  DEBIAN_FRONTEND=noninteractive sudo apt-get install -y -qq tomcat9 tomcat9-admin 2>&1 | tail -3
else
  echo "Tomcat ${TOMCAT_VERSION} already installed"
fi

# --- cloudflared ---
if ! command -v cloudflared &> /dev/null; then
  echo "Installing cloudflared..."
  curl -sL "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64" -o /tmp/cloudflared
  chmod +x /tmp/cloudflared
  sudo mv /tmp/cloudflared /usr/local/bin/cloudflared
fi

# --- Build guacamole-server ---
echo "[3/9] Building guacamole-server v${GUAC_VERSION}..."
if ! command -v guacd &> /dev/null; then
  cd /tmp
  if [ ! -d "guacamole-server-${GUAC_VERSION}" ]; then
    wget -q "https://downloads.apache.org/guacamole/${GUAC_VERSION}/source/guacamole-server-${GUAC_VERSION}.tar.gz" -O guacamole-server.tar.gz
    tar -xzf guacamole-server.tar.gz
  fi
  cd "guacamole-server-${GUAC_VERSION}"
  ./configure --with-init-dir=/etc/init.d 2>&1 | tail -5
  make -j$(nproc) 2>&1 | tail -3
  sudo make install 2>&1 | tail -3
  sudo ldconfig
  echo "guacamole-server installed successfully"
else
  echo "guacd already installed, skipping"
fi

# --- Deploy guacamole-client ---
echo "[4/9] Deploying guacamole-client..."
GUAC_HOME="/etc/guacamole"
sudo mkdir -p "${GUAC_HOME}"/{extensions,lib}

if [ ! -f "${GUAC_HOME}/guacamole.war" ]; then
  wget -q "https://downloads.apache.org/guacamole/${GUAC_VERSION}/binary/guacamole-${GUAC_VERSION}.war" \
    -O /tmp/guacamole.war
  sudo cp /tmp/guacamole.war "${GUAC_HOME}/guacamole.war"
fi

# Link to Tomcat webapps
TOMCAT_WEBAPPS="/var/lib/tomcat${TOMCAT_VERSION}/webapps"
sudo ln -sf "${GUAC_HOME}/guacamole.war" "${TOMCAT_WEBAPPS}/guacamole.war"

# Set GUACAMOLE_HOME
if ! grep -q "GUACAMOLE_HOME" /etc/default/tomcat9 2>/dev/null; then
  echo "GUACAMOLE_HOME=${GUAC_HOME}" | sudo tee -a /etc/default/tomcat9
fi

# --- Configure guacamole.properties ---
echo "[5/9] Configuring Guacamole..."
sudo tee "${GUAC_HOME}/guacamole.properties" > /dev/null << EOF
guacd-hostname: localhost
guacd-port:     4822
auth-provider:  guacauth
EOF

# --- Configure SQLite auth ---
echo "[6/9] Setting up authentication..."
if [ ! -f "${GUAC_HOME}/guacamole.db" ]; then
  # Download auth extension if needed
  if [ ! -f "${GUAC_HOME}/extensions/guacamole-auth-sqlite-${GUAC_VERSION}.jar" ]; then
    wget -q "https://downloads.apache.org/guacamole/${GUAC_VERSION}/extensions/guacamole-auth-sqlite-${GUAC_VERSION}.jar" \
      -O "${GUAC_HOME}/extensions/guacamole-auth-sqlite-${GUAC_VERSION}.jar" 2>/dev/null || true
  fi
  
  # Create initial user-mapping.xml as fallback
  sudo tee "${GUAC_HOME}/user-mapping.xml" > /dev/null << EOF
<?xml version="1.0" encoding="UTF-8"?>
<user-mapping>
    <authorize username="guacadmin" password="${GUAC_PASSWORD}">
        <connection name="Local Desktop">
            <protocol>vnc</protocol>
            <param name="hostname">localhost</param>
            <param name="port">5900</param>
            <param name="password">${VNC_PASSWORD}</param>
        </connection>
    </authorize>
</user-mapping>
EOF
  echo "Created user-mapping.xml with guacadmin user"
fi

# --- VNC Password ---
echo "[7/9] Setting VNC password..."
mkdir -p "$USER_HOME/.vnc"
x11vnc -storepasswd "$VNC_PASSWORD" "$USER_HOME/.vnc/passwd" 2>&1 | tail -1

# --- Systemd services or direct mode ---
TUNNEL_LOG=""
if [ "$USE_SYSTEMD" = true ]; then
  echo "[8/9] Installing services..."
  sudo mkdir -p /var/log/bux
  TUNNEL_LOG="/var/log/bux/guacamole-tunnel.log"
  
  # Create guacd systemd service
  sudo tee /etc/systemd/system/guacd.service > /dev/null << 'EOF'
[Unit]
Description=Guacamole Proxy Daemon
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/sbin/guacd -f
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

  sudo systemctl daemon-reload
  sudo systemctl enable guacd 2>/dev/null
else
  echo "[8/9] Direct mode (no systemd)..."
  LOG_DIR="$USER_HOME/.workstation-webspace-guacamole/logs"
  mkdir -p "$LOG_DIR"
  TUNNEL_LOG="$LOG_DIR/tunnel.log"
fi

# --- Apply branding ---
echo "[9/9] Applying Workstation Center branding..."
bash "${SCRIPT_DIR}/scripts/branding/apply-branding.sh"

# Create /workstation route
sudo ln -sf "${TOMCAT_WEBAPPS}/guacamole" "${TOMCAT_WEBAPPS}/workstation" 2>/dev/null || true

# --- pbcopy/pbpaste ---
if ! grep -q "pbcopy" "$USER_HOME/.bashrc" 2>/dev/null; then
  cat >> "$USER_HOME/.bashrc" << 'EOF'

# Linux version of OSX pbcopy and pbpaste.
alias pbcopy='xsel --clipboard --input'
alias pbpaste='xsel --clipboard --output'
EOF
fi

# --- Start ---
echo ""
echo "Starting services..."

# Determine desktop command based on edition
if [ "$EDITION" = "pro" ]; then
  DESKTOP_CMD="startxfce4"
else
  DESKTOP_CMD="fluxbox"
fi

if [ "$USE_SYSTEMD" = true ]; then
  sudo systemctl start guacd 2>/dev/null || true
  sudo systemctl restart tomcat9 2>/dev/null || true
  
  # Ensure clean X state
  rm -f /tmp/.X99-lock /tmp/.X11-unix/X99 2>/dev/null || true
  
  # Start desktop
  Xvfb :99 -screen 0 "${RES_X}x${RES_Y}x${DEPTH}" -ac &
  sleep 1
  DISPLAY=:99 $DESKTOP_CMD &
  sleep 3
  DISPLAY=:99 x11vnc -display :99 -forever -shared -rfbauth "$USER_HOME/.vnc/passwd" -rfbport 5900 -noxdamage -noxrecord -noxfixes &
else
  # Direct mode
  truncate -s 0 "$TUNNEL_LOG" 2>/dev/null || true

  # Kill existing
  pkill -f "Xvfb :99" 2>/dev/null || true
  pkill -f "fluxbox" 2>/dev/null || true
  pkill -f "startxfce4" 2>/dev/null || true
  pkill -f "xfce4-session" 2>/dev/null || true
  pkill -f "x11vnc" 2>/dev/null || true
  pkill -f guacd 2>/dev/null || true
  sleep 1

  # Start guacd
  nohup /usr/local/sbin/guacd -f > /tmp/guacd.log 2>&1 &
  sleep 2

  # Start Tomcat with correct CATALINA_BASE
  export CATALINA_HOME="/usr/share/tomcat${TOMCAT_VERSION}"
  export CATALINA_BASE="/var/lib/tomcat${TOMCAT_VERSION}"
  sudo -E /usr/share/tomcat${TOMCAT_VERSION}/bin/catalina.sh start 2>/dev/null || true
  sleep 3

  # Start desktop
  Xvfb :99 -screen 0 "${RES_X}x${RES_Y}x${DEPTH}" -ac &
  sleep 1
  DISPLAY=:99 $DESKTOP_CMD &
  sleep 3
  DISPLAY=:99 x11vnc -display :99 -forever -shared -rfbauth "$USER_HOME/.vnc/passwd" -rfbport 5900 -noxdamage -noxrecord -noxfixes &
fi

sleep 2

# --- Try cloudflared ---
CF_URL=""
if command -v cloudflared &> /dev/null; then
  echo ""
  echo "Attempting cloudflare tunnel..."
  truncate -s 0 "$TUNNEL_LOG" 2>/dev/null || true
  nohup cloudflared tunnel --no-autoupdate --url http://127.0.0.1:8080 > "$TUNNEL_LOG" 2>&1 &
  CF_PID=$!
  
  for i in $(seq 1 15); do
    CF_URL=$(grep -o 'https://[a-zA-Z0-9-]*\.trycloudflare\.com' "$TUNNEL_LOG" 2>/dev/null | tail -1)
    [ -n "$CF_URL" ] && break
    kill -0 $CF_PID 2>/dev/null || break
    sleep 1
  done
fi

# --- Agent workspace ---
if [ "$AGENT_WORKSPACE" = true ]; then
  echo ""
  echo "=== Setting up Agent Workspace ==="
  curl -fsSL https://raw.githubusercontent.com/reflecterlabs/alpine-opencode-gentleai/main/setup.sh | bash
  echo "Agent workspace setup complete."
fi

# --- Print access info ---
echo ""
echo "=== Ready ==="
echo ""
echo "Edition: ${EDITION^}"
if [ -n "$CF_URL" ]; then
  echo "Public URL:  ${CF_URL}/workstation"
  echo ""
  echo "Or use direct access:"
fi
echo "Local URL:   http://localhost:8080/workstation"
echo "VNC direct:  vnc://localhost:5900"
echo ""
echo "Login:"
echo "  Username:  guacadmin"
echo "  Password:  ${GUAC_PASSWORD}"
if [ "$AGENT_WORKSPACE" = true ]; then
  echo ""
  echo "Agent:      OpenCode GentleAI installed"
fi
echo ""
echo "--- How to access ---"
echo "1. Open: http://localhost:8080/workstation in your browser"
echo "2. Login with guacadmin / your GUAC_PASSWORD"
echo "3. Enjoy Workstation Center OS ${EDITION^} Edition!"
